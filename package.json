{
  "name": "rspress-monorepo",
  "private": true,
  "scripts": {
    "build": "cross-env NX_DAEMON=false nx run-many -t build --exclude @rspress-fixture/* --exclude @rspress/docs",
    "build:website": "cross-env NX_DAEMON=false nx run @rspress/docs:build",
    "bump": "bumpp",
    "check-dependency-version": "check-dependency-version-consistency . --ignore-dep @rspress/core --ignore-package @rspress-fixture/react-18 --ignore-package @rspress-fixture/react-router-dom-6 --ignore-package @rspress-fixture/tailwind-v4 && echo 0",
    "check-spell": "pnpm cspell && heading-case",
    "dev": "cross-env NX_DAEMON=false NX_REJECT_UNKNOWN_LOCAL_CACHE=0 nx run-many -t dev --exclude @rspress-fixture/* --exclude @rspress/docs",
    "dev:website": "cross-env NX_DAEMON=false NX_REJECT_UNKNOWN_LOCAL_CACHE=0 nx run @rspress/docs:dev",
    "format": "rslint --fix && prettier . --write && heading-case --write",
    "generate-release-pr": "zx scripts/generateReleasePr.mjs",
    "lint": "rslint --type-check && prettier . --check && pnpm run check-spell",
    "prepare": "skills-package-manager install && pnpm run build && simple-git-hooks",
    "preview:website": "cd website && npm run preview",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:unit": "rstest run",
    "update:rsbuild": "npx taze minor --include /rsbuild/ -w -r -l"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec nano-staged"
  },
  "nano-staged": {
    "*.{md,mdx,css,less,scss,json,jsonc,json5}": [
      "prettier --write",
      "heading-case --write"
    ],
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "rslint --fix",
      "prettier --write"
    ],
    "package.json": [
      "pnpm run check-dependency-version",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "1.61.1",
    "@rsbuild/plugin-react": "~2.0.1",
    "@rslint/core": "^0.6.4",
    "@rspress/config": "workspace:*",
    "@rstest/adapter-rslib": "0.10.5",
    "@rstest/core": "^0.10.5",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.8.1",
    "@typescript/native-preview": "7.0.0-dev.20260628.1",
    "bumpp": "^11.1.0",
    "check-dependency-version-consistency": "^5.0.1",
    "cross-env": "^10.1.0",
    "cross-spawn": "^7.0.6",
    "cspell": "^9.8.0",
    "cspell-ban-words": "^0.0.4",
    "get-port": "5.1.1",
    "heading-case": "^1.1.3",
    "nano-staged": "^0.9.0",
    "nx": "21.6.11",
    "path-serializer": "0.6.0",
    "playwright": "1.61.1",
    "prettier": "3.9.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "simple-git-hooks": "^2.13.1",
    "skills-package-manager": "0.11.0",
    "tree-kill": "^1.2.2",
    "zx": "^8.8.5"
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=11.10.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
