{
  "name": "create-rspress",
  "version": "2.0.16",
  "description": "Create a new Rspress project",
  "homepage": "https://rspress.rs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-infra-dev/rspress.git",
    "directory": "packages/create-rspress"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "bin": {
    "create-rspress": "./bin.js"
  },
  "files": [
    "template-*/**",
    "dist",
    "bin.js"
  ],
  "scripts": {
    "build": "node ./scripts/generate-theme-templates.mjs && rslib build",
    "dev": "node ./scripts/generate-theme-templates.mjs && rslib build -w",
    "start": "node ./dist/index.js"
  },
  "dependencies": {
    "create-rstack": "2.1.3"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.9",
    "@rslib/core": "0.23.2",
    "@types/node": "^22.8.1",
    "rsbuild-plugin-publint": "^1.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
