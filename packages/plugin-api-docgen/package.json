    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.9",
    "@rslib/core": "0.23.0",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.8.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.15.1",
    "rsbuild-plugin-publint": "^1.0.0",
    "rsbuild-plugin-virtual-module": "0.4.4",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@rspress/core": "workspace:^2.0.10",
