{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: ['config:recommended', 'schedule:weekly'],
  packageRules: [
    // Use chore as semantic commit type for commit messages
    {
      matchPackagePatterns: ['*'],
      semanticCommitType: 'chore',
      // always bump package.json
      rangeStrategy: 'bump',
    },
    {
      groupName: 'modern-js',
      matchPackagePatterns: ['modern-js'],
      groupSlug: 'modern-js',
    },
    // Group @docsearch packages together (css + react always updated in tandem)
    {
      groupName: 'docsearch',
      matchPackagePatterns: ['@docsearch/'],
      groupSlug: 'docsearch',
    },
    // Group GitHub Actions together to reduce PR noise
    {
      groupName: 'github-actions',
      matchManagers: ['github-actions'],
      groupSlug: 'github-actions',
    },
    // Group dev tools that are low-risk to update together
    {
      groupName: 'dev-tools',
      matchPackageNames: [
        'cspell',
        '@biomejs/biome',
        'prettier',
        'lint-staged',
        '@microsoft/api-extractor',
        'rimraf',
      ],
      groupSlug: 'dev-tools',
    },
    // Batch all patch updates
    {
      groupName: 'all patch dependencies',
      groupSlug: 'all-patch',
      matchPackagePatterns: ['*'],
      matchUpdateTypes: ['patch'],
    },
    // Group Rstack ecosystem packages (placed after all-patch to take precedence)
    {
      groupName: 'rstack',
      matchPackagePatterns: [
        'rsbuild',
        'rsdoctor',
        'rslib',
        'rspack',
        'rstest',
        'rspress',
        'create-rstack',
      ],
      groupSlug: 'rstack',
    },
    // Group Shiki packages (placed after all-patch to take precedence)
    {
      groupName: 'shiki',
      matchPackagePatterns: ['shiki', '@shikijs/'],
      groupSlug: 'shiki',
    },
    // manually update peer dependencies
    {
      matchDepTypes: ['peerDependencies'],
      enabled: false,
    },
  ],
  ignoreDeps: [
    // manually updating
    'typescript',
    // align Node.js version minimum requirements
    '@types/node',
    'node',
  ],
}
